# Copy to .env and fill in your values. Do not commit .env (it is in .gitignore).

# Discord bot token (required to run the bot)
DISCORD_TOKEN=

# MySQL database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_AUTOCOMMIT=true

# YouTube Data API (required for yt_checker videochecker task)
YOUTUBE_API_KEY=

# Log ingestion API (other bots POST custom audit events)
MANAGEMENT_LOG_API_SECRET=
LOG_HTTP_PORT=8766
MANAGEMENT_LOG_HTTP_URL=http://127.0.0.1:8766/api/logs
